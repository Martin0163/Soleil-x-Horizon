<style>
}

.site-header {
  height:var(--header--height);
  position: sticky;
  top: var(--announcement-height);
  z-index: 50;
}

.site-header.is-scrolled {
box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
background: linear-gradient(90deg, #e6b800 0%, #ffca00 100%);
}

.site-header.is-hidden {
transform: translateY(-100%);
opacity: 0;
pointer-events: none;
}

.header-inner {
display: flex;
align-items: center;
justify-content: space-between;
padding: var(--space-md) var(--space-xl);
max-width: 1536px;
margin: 0 auto;
}

/* Logo */
.site-logo {
display: flex;
align-items: center;
transition: transform var(--duration-base) var(--ease-out);
}

.site-logo:hover {
transform: scale(1.05);
}

.site-logo img {
max-height: 60px;
width: auto;
}

.site-logo-text {
font-size: var(--font-size-2xl);
font-weight: var(--font-weight-bold);
color: var(--color-black);
}

/* Navigation */
.main-nav {
display: flex;
align-items: center;
gap: var(--space-xl);
}

.nav-links {
display: flex;
align-items: center;
gap: var(--space-lg);
}

.nav-item {
position: relative;
}

.nav-link {
position: relative;
font-weight: var(--font-weight-semibold);
font-size: var(--font-size-base);
color: var(--color-black);
padding: var(--space-sm) 0;
transition: color var(--duration-base) var(--ease-out),
transform var(--duration-base) var(--ease-out);
}

.nav-link:hover {
color: var(--color-yellow-dark);
transform: translateY(-2px);
}

.nav-link::after {
content: '';
position: absolute;
bottom: 0;
left: 0;
width: 0;
height: 2px;
background: var(--color-yellow-dark);
transition: width var(--duration-base) var(--ease-out);
}

.nav-link:hover::after,
.nav-link.active::after {
width: 100%;
}

/* Dropdown Menu */
.nav-dropdown {
position: absolute;
top: 100%;
left: 0;
min-width: 250px;
background: var(--color-white);
border: 1px solid var(--color-gray-200);
border-radius: var(--radius-lg);
box-shadow: var(--shadow-xl);
padding: var(--space-md);
opacity: 0;
visibility: hidden;
transform: translateY(-10px);
transition: opacity var(--duration-base) var(--ease-out),
transform var(--duration-base) var(--ease-out),
visibility var(--duration-base) var(--ease-out);
z-index: var(--z-dropdown);
}

.nav-item:hover .nav-dropdown {
opacity: 1;
visibility: visible;
transform: translateY(0);
}

.nav-dropdown-link {
display: block;
padding: var(--space-sm) var(--space-md);
color: var(--color-gray-700);
border-radius: var(--radius-md);
transition: background-color var(--duration-fast) var(--ease-out),
color var(--duration-fast) var(--ease-out);
}

.nav-dropdown-link:hover {
background-color: var(--color-gray-50);
color: var(--color-black);
}

/* Header Actions */
.header-actions {
display: flex;
align-items: center;
gap: var(--space-md);
}

.header-icon {
position: relative;
width: 40px;
height: 40px;
display: flex;
align-items: center;
justify-content: center;
border-radius: var(--radius-full);
transition: background-color var(--duration-fast) var(--ease-out),
transform var(--duration-fast) var(--ease-out);
color: var(--color-black);
background: none;
border: none;
cursor: pointer;
}

.header-icon:hover {
background-color: rgba(0, 0, 0, 0.1);
transform: scale(1.1);
}

.header-icon:focus-visible {
outline: 2px solid var(--color-yellow);
outline-offset: 2px;
}

.header-icon svg {
width: 20px;
height: 20px;
stroke: currentColor;
}

/* Cart Count Badge */
.cart-count {
position: absolute;
top: -4px;
right: -4px;
min-width: 20px;
height: 20px;
display: flex;
align-items: center;
justify-content: center;
background: var(--color-error);
color: var(--color-white);
font-size: var(--font-size-xs);
font-weight: var(--font-weight-bold);
border-radius: var(--radius-full);
padding: 0 var(--space-xs);
animation: scaleIn var(--duration-base) ease-out;
}

.cart-count:empty {
display: none;
}

/* Mobile Menu */
.mobile-menu-toggle {
  display: none;
  flex-direction: column;
  gap: 5px;
  width: 30px;
  height: 30px;
  padding: 0;
  background: none;
  border: none;
  cursor: pointer;
}

.mobile-menu-toggle span {
  display: block;
  width: 100%;
  height: 2px;
  background: var(--color-black);
  transition: transform var(--duration-base) var(--ease-out),
              opacity var(--duration-base) var(--ease-out);
}

.mobile-menu-toggle.active span:nth-child(1) {
  transform: translateY(7px) rotate(45deg);
}

.mobile-menu-toggle.active span:nth-child(2) {
  opacity: 0;
}

.mobile-menu-toggle.active span:nth-child(3) {
  transform: translateY(-7px) rotate(-45deg);
}

/* Responsive */
@media (max-width: 1024px) {
  .header-inner {
    padding: var(--space-md);
  }
  
  .mobile-menu-toggle {
    display: flex;
  }
  
  .main-nav {
    position: fixed;
    top: 70px;
    left: -100%;
    width: 100%;
    height: calc(100vh - 70px);
    background: var(--color-white);
    flex-direction: column;
    align-items: flex-start;
    padding: var(--space-xl);
    transition: left var(--duration-base) var(--ease-out);
    overflow-y: auto;
    z-index: var(--z-fixed);
    box-shadow: var(--shadow-xl);
  }
  
  .main-nav.active {
    left: 0;
  }
  
  .nav-links {
    flex-direction: column;
    align-items: flex-start;
    width: 100%;
  }
  
  .nav-link {
    font-size: var(--font-size-lg);
    padding: var(--space-md) 0;
    width: 100%;
  }

  .nav-dropdown {
    position: static;
    opacity: 1;
    visibility: visible;
    transform: none;
    box-shadow: none;
    border: none;
    margin-top: var(--space-sm);
    margin-left: var(--space-md);
  }

  .has-dropdown .nav-link::after {
    content: '+';
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    font-size: var(--font-size-xl);
    transition: transform var(--duration-base) var(--ease-out);
  }

  .has-dropdown.is-open .nav-link::after {
    transform: translateY(-50%) rotate(45deg);
  }
}

  .header-actions {
    gap: var(--space-sm);
  }

  .header-icon {
    width: 36px;
    height: 36px;
  }

  .header-icon svg {
    width: 18px;
    height: 18px;
  }
}

/* Ocultar menú móvil en desktop */
.mobile-menu-wrapper {
  display: none;
}

@media (max-width: 1024px) {
  .mobile-menu-wrapper {
    display: block;
  }
  .nav-links {
    display: none;
  }
}

@media (min-width: 1025px) {
  .nav-links {
    display: flex;
  }
  .mobile-menu-wrapper {
    display: none !important;
  }
}
</style>



<script>
document.addEventListener('DOMContentLoaded', function() {
try {
const header = document.querySelector('.site-header.sticky-header');
const mobileMenuToggle = document.getElementById('mobile-menu-toggle');
const mainNav = document.getElementById('main-navigation');
      
if (!header) return;

let lastScrollTop = 0;
const scrollThreshold = 100;

// Enhanced scroll handling with performance optimization
let ticking = false;
function handleScroll() {
if (!ticking) {
requestAnimationFrame(() => {
try {
const scrollTop = window.pageYOffset || document.documentElement.scrollTop;

// Add scrolled class
header.classList.toggle('is-scrolled', scrollTop > 50);

// Hide/show header on scroll
if (scrollTop > scrollThreshold) {
if (scrollTop > lastScrollTop && scrollTop > 200) {
header.classList.add('is-hidden');
} else {
header.classList.remove('is-hidden');
}
} else {
header.classList.remove('is-hidden');
}

lastScrollTop = Math.max(0, scrollTop);
} catch (error) {
console.error('Scroll handler error:', error);
}
ticking = false;
});
ticking = true;
}
}

window.addEventListener('scroll', handleScroll, { passive: true });

// Enhanced mobile menu with accessibility
if (mobileMenuToggle && mainNav) {
mobileMenuToggle.addEventListener('click', function() {
try {
const isOpen = mainNav.classList.toggle('active');
this.classList.toggle('active', isOpen);
document.body.classList.toggle('menu-open', isOpen);
            
// Update ARIA attributes
this.setAttribute('aria-expanded', isOpen);
            
// Focus management
if (isOpen) {
const firstLink = mainNav.querySelector('a');
if (firstLink) {
setTimeout(() => firstLink.focus(), 300);
}
}
} catch (error) {
console.error('Mobile menu toggle error:', error);
}
});

// Close menu on outside click
document.addEventListener('click', function(e) {
if (mainNav.classList.contains('active') && 
!mainNav.contains(e.target) && 
!mobileMenuToggle.contains(e.target)) {
closeMobileMenu();
}
});

// Handle submenu toggles on mobile
// === MOBILE SIDE-MENU SUBMENU TOGGLES ===
const mobileToggles = document.querySelectorAll('.mobile-toggle');

mobileToggles.forEach(toggle => {
toggle.addEventListener('click', function () {
const parent = this.closest('.mobile-item');
parent.classList.toggle('is-open');
});
});
}

function closeMobileMenu() {
if (mainNav && mobileMenuToggle) {
mainNav.classList.remove('active');
mobileMenuToggle.classList.remove('active');
document.body.classList.remove('menu-open');
mobileMenuToggle.setAttribute('aria-expanded', 'false');
}
}

// Enhanced keyboard navigation
document.addEventListener('keydown', function(e) {
if (e.key === 'Escape') {
if (mainNav?.classList.contains('active')) {
closeMobileMenu();
mobileMenuToggle?.focus();
}
}
});

// Search toggle functionality
const searchToggle = document.getElementById('search-toggle');
if (searchToggle) {
searchToggle.addEventListener('click', function() {
try {
if (window.searchManager) {
window.searchManager.openSearch();
this.setAttribute('aria-expanded', 'true');
}
} catch (error) {
console.error('Search toggle error:', error);
}
});
}

// Cart toggle functionality
const cartToggle = document.getElementById('cart-toggle');
if (cartToggle) {
cartToggle.addEventListener('click', function() {
try {
if (window.ajaxCart) {
window.ajaxCart.toggleCartDrawer();
const isOpen = document.querySelector('.mini-cart.is-open');
this.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
}
} catch (error) {
console.error('Cart toggle error:', error);
}
});
}

// Update cart count when cart changes
document.addEventListener('cart:updated', function(e) {
try {
const cartCount = document.querySelector('.cart-count');
const cartToggle = document.getElementById('cart-toggle');
          
if (cartCount && cartToggle) {
const itemCount = e.detail.cart.item_count;
cartCount.textContent = itemCount;
            
// Update ARIA label
const itemsText = itemCount === 1 ? 'item' : 'items';
cartToggle.setAttribute('aria-label', `Cart (${itemCount} ${itemsText})`);
           
// Show/hide count badge
cartCount.style.display = itemCount > 0 ? 'flex' : 'none';
}
} catch (error) {
console.error('Cart count update error:', error);
}
});

} catch (error) {
console.error('Header initialization error:', error);
}
});
</script>

