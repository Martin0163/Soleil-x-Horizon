{% comment %}
  ============================================================================
  SOLEIL BRANDS SECTION - Adapted for Horizon Theme
  ============================================================================
  
  Source: Codigo Soleil theme (brands.liquid)
  Integration Date: Current
  Adapted By: Senior Shopify Theme Engineer
  
  Purpose:
  - Showcase partner/featured brands in an elegant grid
  - Brand logos with hover effects and descriptions
  - Responsive grid layout
  - Call-to-action button
  
  Adaptations Made:
  - Integrated Horizon's color scheme system
  - Added Horizon's spacing utilities
  - Uses Horizon's button classes
  - Enhanced with Horizon's responsive grid
  - Added accessibility improvements
  
  Dependencies:
  - Horizon base.css for core styles
  - Horizon color scheme variables
  - Horizon button components
  - snippets/soleil-brand.liquid (will be created in Phase 3)
  
  Future Developers:
  Aquí puedes agregar nueva información al código sin romperlo.
  - Add new brand block types in the schema
  - Customize grid columns in CSS
  - Modify hover effects
  
  ============================================================================
{% endcomment %}

{% comment %} START: Section Container with Horizon Color Scheme Support {% endcomment %}
<section 
  class="soleil-brands-section section-{{ section.id }}-padding"
  data-section-id="{{ section.id }}"
>
  {% comment %} Aquí puedes agregar nueva información al código sin romperlo {% endcomment %}

  {% comment %} START: Main Content Container - Using Horizon's Page Width System {% endcomment %}
  <div class="page-width-{{ section.settings.page_width }}">

    {% comment %} START: Section Header - Adapted from Soleil {% endcomment %}
    {% if section.settings.show_header %}
    <div class="soleil-section-header text-center spacing-style">
      {% if section.settings.subtitle != blank %}
        <span class="soleil-section-label h6">{{ section.settings.subtitle | escape }}</span>
      {% endif %}
      <h2 class="soleil-section-title h2">{{ section.settings.title | default: 'Our Brands' | escape }}</h2>
      {% if section.settings.description != blank %}
        <p class="soleil-section-description paragraph">{{ section.settings.description | escape }}</p>
      {% endif %}
      {% comment %} Aquí puedes agregar nueva información al código sin romperlo {% endcomment %}
    </div>
    {% endif %}
    {% comment %} END: Section Header {% endcomment %}

    {% comment %} START: Brands Grid - Responsive Layout {% endcomment %}
    {% if section.blocks.size > 0 %}
      <div class="soleil-brands-grid" data-brands-grid>
        {% for block in section.blocks %}
          {% if block.type == 'brand' %}
            <div class="soleil-brand-item animate-on-scroll" {{ block.shopify_attributes }}>
              {% comment %} START: Brand Card Content {% endcomment %}
              <div class="soleil-brand-card border-style">
                {% if block.settings.brand_logo %}
                  <div class="soleil-brand-logo">
                    {%- liquid
                      assign logo_width = block.settings.brand_logo.width | default: 400
                      assign logo_height = block.settings.brand_logo.height | default: 400
                    -%}
                    {% if block.settings.brand_url != blank %}
                      <a href="{{ block.settings.brand_url }}" aria-label="{{ block.settings.brand_name | escape }}">
                    {% endif %}
                        <img 
                          src="{{ block.settings.brand_logo | image_url: width: 400 }}" 
                          srcset="
                            {{ block.settings.brand_logo | image_url: width: 200 }} 200w,
                            {{ block.settings.brand_logo | image_url: width: 300 }} 300w,
                            {{ block.settings.brand_logo | image_url: width: 400 }} 400w
                          "
                          sizes="(min-width: 990px) 20vw, (min-width: 750px) 25vw, 50vw"
                          alt="{{ block.settings.brand_name | escape }}"
                          width="{{ logo_width }}"
                          height="{{ logo_height }}"
                          loading="lazy"
                        >
                    {% if block.settings.brand_url != blank %}
                      </a>
                    {% endif %}
                  </div>
                {% endif %}
                
                {% if block.settings.brand_name != blank or block.settings.brand_description != blank %}
                  <div class="soleil-brand-content">
                    {% if block.settings.brand_name != blank %}
                      <h3 class="soleil-brand-name h5">{{ block.settings.brand_name | escape }}</h3>
                    {% endif %}
                    {% if block.settings.brand_description != blank %}
                      <p class="soleil-brand-description paragraph">{{ block.settings.brand_description | escape }}</p>
                    {% endif %}
                  </div>
                {% endif %}
              </div>
              {% comment %} END: Brand Card Content {% endcomment %}
              {% comment %} Aquí puedes agregar nueva información al código sin romperlo {% endcomment %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% else %}
      {% comment %} START: Empty State - Theme Editor Placeholder {% endcomment %}
      <div class="soleil-brands-empty text-center spacing-style">
        <p class="paragraph">{{ 'sections.brands.empty' | t | default: 'No brands to display. Add brands in the theme editor.' }}</p>
      </div>
      {% comment %} END: Empty State {% endcomment %}
    {% endif %}
    {% comment %} END: Brands Grid {% endcomment %}

    {% comment %} START: Call to Action Button {% endcomment %}
    {% if section.settings.show_cta and section.settings.cta_text != blank %}
      <div class="soleil-brands-cta text-center spacing-style">
        <a href="{{ section.settings.cta_link }}" class="button button-primary">
          {{ section.settings.cta_text | escape }}
        </a>
      </div>
      {% comment %} Aquí puedes agregar nueva información al código sin romperlo {% endcomment %}
    {% endif %}
    {% comment %} END: Call to Action Button {% endcomment %}

  </div>
  {% comment %} END: Main Content Container {% endcomment %}

</section>
{% comment %} END: Section Container {% endcomment %}

{% comment %}
  ============================================================================
  STYLES - Adapted from Soleil with Horizon Integration
  ============================================================================
  
  Modifications:
  - Uses Horizon's CSS custom properties
  - Integrated with Horizon's color scheme system
  - Responsive breakpoints match Horizon's
  - Grid system compatible with Horizon
  
  Aquí puedes agregar nueva información al código sin romperlo.
  ============================================================================
{% endcomment %}

<style>
/* START: Base Section Styles */
.soleil-brands-section {
  padding: var(--padding-4xl) 0;
}

/* START: Section Header Styles */
.soleil-section-header {
  margin-bottom: var(--margin-4xl);
}

.soleil-section-label {
  display: inline-block;
  font-size: var(--font-size--sm);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--color-primary);
  margin-bottom: var(--margin-sm);
}

.soleil-section-title {
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 700;
  color: var(--color-foreground);
  margin-bottom: var(--margin-md);
}

.soleil-section-description {
  font-size: var(--font-size--lg);
  color: rgb(var(--color-foreground-rgb) / 0.7);
  max-width: 600px;
  margin: 0 auto;
  line-height: 1.6;
}
/* END: Section Header Styles */

/* START: Brands Grid Layout */
.soleil-brands-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: var(--gap-xl);
  margin-bottom: var(--margin-3xl);
}

@media (min-width: 750px) {
  .soleil-brands-grid {
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--gap-2xl);
  }
}

@media (min-width: 990px) {
  .soleil-brands-grid {
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  }
}
/* END: Brands Grid Layout */

/* START: Brand Item Styles */
.soleil-brand-item {
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.6s ease-out, transform 0.6s ease-out;
}

.soleil-brand-item.is-visible {
  opacity: 1;
  transform: translateY(0);
}

.soleil-brand-card {
  display: flex;
  flex-direction: column;
  height: 100%;
  padding: var(--padding-xl);
  background: var(--color-background);
  border-radius: var(--style-border-radius-lg, 12px);
  border: 1px solid rgb(var(--color-border-rgb) / 0.1);
  transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  overflow: hidden;
}

.soleil-brand-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 24px rgb(var(--color-shadow-rgb) / 0.12);
  border-color: rgb(var(--color-primary-rgb) / 0.3);
}
/* END: Brand Item Styles */

/* START: Brand Logo Styles */
.soleil-brand-logo {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 120px;
  margin-bottom: var(--margin-lg);
  position: relative;
}

.soleil-brand-logo img {
  max-width: 100%;
  height: auto;
  max-height: 100px;
  object-fit: contain;
  filter: grayscale(100%);
  opacity: 0.7;
  transition: filter 0.3s ease, opacity 0.3s ease, transform 0.3s ease;
}

.soleil-brand-card:hover .soleil-brand-logo img {
  filter: grayscale(0%);
  opacity: 1;
  transform: scale(1.05);
}

.soleil-brand-logo a {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}
/* END: Brand Logo Styles */

/* START: Brand Content Styles */
.soleil-brand-content {
  text-align: center;
  margin-top: auto;
}

.soleil-brand-name {
  font-size: var(--font-size--lg);
  font-weight: 600;
  color: var(--color-foreground);
  margin-bottom: var(--margin-xs);
}

.soleil-brand-description {
  font-size: var(--font-size--sm);
  color: rgb(var(--color-foreground-rgb) / 0.6);
  line-height: 1.5;
  margin: 0;
}
/* END: Brand Content Styles */

/* START: Empty State Styles */
.soleil-brands-empty {
  padding: var(--padding-4xl) 0;
  color: rgb(var(--color-foreground-rgb) / 0.5);
}
/* END: Empty State Styles */

/* START: CTA Styles */
.soleil-brands-cta {
  margin-top: var(--margin-3xl);
}
/* END: CTA Styles */

/* START: Animation Classes */
.animate-on-scroll {
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.6s ease-out, transform 0.6s ease-out;
}

.animate-on-scroll.is-visible {
  opacity: 1;
  transform: translateY(0);
}
/* END: Animation Classes */

/* START: Responsive Adjustments */
@media (max-width: 749px) {
  .soleil-brands-section {
    padding: var(--padding-3xl) 0;
  }

  .soleil-section-title {
    font-size: clamp(1.75rem, 5vw, 2.5rem);
  }

  .soleil-brands-grid {
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: var(--gap-lg);
  }

  .soleil-brand-card {
    padding: var(--padding-lg);
  }

  .soleil-brand-logo {
    min-height: 100px;
  }

  .soleil-brand-logo img {
    max-height: 80px;
  }
}
/* END: Responsive Adjustments */
</style>

{% comment %}
  ============================================================================
  JAVASCRIPT - Scroll Animation with Intersection Observer
  ============================================================================
  
  Adaptations:
  - Uses Intersection Observer API for performance
  - Staggered animation for visual appeal
  - Fallback for older browsers
  - Compatible with Horizon's existing JS
  
  Aquí puedes agregar nueva información al código sin romperlo.
  ============================================================================
{% endcomment %}

<script>
  // START: Brands Section JavaScript - Adapted for Horizon
  document.addEventListener('DOMContentLoaded', function() {
    try {
      const brandItems = document.querySelectorAll('.soleil-brand-item');
      
      if (brandItems.length === 0) return;

      if ('IntersectionObserver' in window) {
        const observerOptions = {
          threshold: 0.1,
          rootMargin: '0px 0px -50px 0px'
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry, index) => {
            if (entry.isIntersecting) {
              // Stagger animation for visual appeal
              setTimeout(() => {
                entry.target.classList.add('is-visible');
              }, index * 100);
              observer.unobserve(entry.target);
            }
          });
        }, observerOptions);

        brandItems.forEach(item => observer.observe(item));
      } else {
        // Fallback for browsers without IntersectionObserver
        brandItems.forEach(item => item.classList.add('is-visible'));
      }

      // Aquí puedes agregar nueva información al código sin romperlo
      // Add custom JavaScript functionality here

    } catch (error) {
      console.error('Brands section initialization error:', error);
    }
  });
  // END: Brands Section JavaScript
</script>

{% comment %}
  ============================================================================
  SCHEMA - Section Settings Configuration
  ============================================================================
  
  Adaptations:
  - Integrated Horizon's color_scheme setting
  - Added page_width setting for Horizon compatibility
  - Preserved all Soleil brand block settings
  - Enhanced with better defaults
  
  Aquí puedes agregar nueva información al código sin romperlo.
  ============================================================================
{% endcomment %}

{% schema %}
{
  "name": "Soleil Brands",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "page_width",
      "label": "Page width",
      "options": [
        {
          "value": "narrow",
          "label": "Narrow"
        },
        {
          "value": "normal",
          "label": "Normal"
        },
        {
          "value": "wide",
          "label": "Wide"
        }
      ],
      "default": "normal"
    },
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "checkbox",
      "id": "show_header",
      "label": "Show section header",
      "default": true
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Premium Beauty"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Our Brands"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Discover our curated selection of premium beauty brands"
    },
    {
      "type": "header",
      "content": "Call to Action"
    },
    {
      "type": "checkbox",
      "id": "show_cta",
      "label": "Show call to action button",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "View All Brands"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "settings": [
        {
          "type": "text",
          "id": "brand_name",
          "label": "Brand name",
          "default": "Brand Name"
        },
        {
          "type": "image_picker",
          "id": "brand_logo",
          "label": "Brand logo",
          "info": "Recommended: Square image, transparent background"
        },
        {
          "type": "url",
          "id": "brand_url",
          "label": "Brand URL",
          "info": "Link to brand page or external website"
        },
        {
          "type": "textarea",
          "id": "brand_description",
          "label": "Brand description",
          "info": "Optional short description of the brand"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Soleil Brands",
      "category": "Soleil",
      "blocks": [
        {
          "type": "brand"
        },
        {
          "type": "brand"
        },
        {
          "type": "brand"
        },
        {
          "type": "brand"
        }
      ]
    }
  ]
}
{% endschema %}