{% comment %}
  Routines Section - Premium Beauty Routines/Looks/Rituals
  Inspired by Sephora’s editorial content: Educational sections for skincare routines, makeup looks, etc.
  Each routine displays title, description, image, related products, and optional CTA.
  Supports vertical stacked or alternating two-column layout on desktop.
  Uses League Spartan for titles, clean body text via theme settings/CSS variables.
  Preserves Horizon's modular structure with blocks and existing snippets.
{% endcomment %}

<div class="section section--routines color-{{ section.settings.color_scheme }}">
  <div class="routines{% if section.settings.alternate_layout %} routines--alternate{% endif %}">
    {% if section.settings.heading != blank %}
      <h2 class="routines__heading routines__heading--{{ section.settings.alignment }}">{{ section.settings.heading }}</h2>
    {% endif %}

    {% for block in section.blocks %}
      {% assign loop_index_mod_2 = forloop.index0 | modulo: 2 %}

      <div class="routines__item{% if section.settings.alternate_layout and loop_index_mod_2 == 1 %} routines__item--reverse{% endif %}" {{ block.shopify_attributes }}>
        <div class="routines__media">
          {% if block.settings.image %}
            {{ block.settings.image | image_url: width: 800 | image_tag:
              loading: 'lazy',
              width: block.settings.image.width,
              height: block.settings.image.height,
              class: 'routines__image',
              alt: block.settings.title | escape
            }}
          {% endif %}
        </div>

        <div class="routines__content">
          {% if block.settings.title != blank %}
            <h3 class="routines__title">{{ block.settings.title }}</h3>
          {% endif %}

          {% if block.settings.description != blank %}
            <div class="routines__description">{{ block.settings.description }}</div>
          {% endif %}

          {% if block.settings.product_list.size > 0 %}
            <div class="routines__products">
              {% for routine_product in block.settings.product_list %}
                {% if routine_product %}
                  {% render 'product-card', product: routine_product  %}
                {% endif %}
              {% endfor %}
            </div>
          {% endif %}

          {% if block.settings.cta_label != blank and block.settings.cta_link != blank %}
            <a href="{{ block.settings.cta_link }}" class="routines__cta button button--minimal">
              {{ block.settings.cta_label }}
            </a>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</div>

{% stylesheet %}
  .routines {
    padding: var(--padding-block-start) var(--padding-inline-start) var(--padding-block-end) var(--padding-inline-end);
    max-width: var(--page-width);
    margin: 0 auto;
  }

  .routines__heading {
    text-align: center;
    margin-bottom: var(--gap-xl);
  }

  .routines__heading--left {
    text-align: left;
  }

  .routines__item {
    display: flex;
    flex-direction: column;
    gap: var(--gap-lg);
    margin-bottom: var(--gap-xl);
    border-radius: var(--border-radius);
    overflow: hidden;
    box-shadow: var(--shadow-subtle);
    transition: box-shadow 0.3s ease;
  }

  .routines__item:hover {
    box-shadow: var(--shadow-hover);
  }

  .routines--alternate .routines__item {
    flex-direction: row;
  }

  .routines__item--reverse {
    flex-direction: row-reverse;
  }

  @media (max-width: 749px) {
    .routines--alternate .routines__item {
      flex-direction: column;
    }
    .routines__item--reverse {
      flex-direction: column;
    }
  }

  .routines__media {
    flex: 1;
    overflow: hidden;
  }

  .routines__image {
    width: 100%;
    height: auto;
    transition: transform 0.3s ease;
  }

  .routines__item:hover .routines__image {
    transform: scale(1.05);
  }

  .routines__content {
    flex: 1;
    padding: var(--gap-lg);
    display: flex;
    flex-direction: column;
    gap: var(--gap-md);
  }

  .routines__title {
    font-family: 'League Spartan', sans-serif;
    font-weight: 700;
    font-size: var(--font-size--xl);
    color: var(--color-foreground);
    margin: 0;
    text-transform: uppercase;
  }

  .routines__description {
    font-family: var(--font-paragraph--family);
    font-size: var(--font-size--body);
    line-height: 1.6;
    color: var(--color-foreground);
    opacity: 0.9;
  }

  .routines__products {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--gap-sm);
  }

  @media (max-width: 749px) {
    .routines__products {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .routines__cta {
    align-self: flex-start;
    padding: var(--padding-sm) var(--padding-lg);
    background: var(--color-accent);
    color: var(--color-background);
    text-decoration: none;
    border-radius: var(--border-radius);
    transition: background 0.3s ease;
  }

  .routines__cta:hover {
    background: var(--color-accent-hover);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Routines",
  "tag": "section",
  "class": "section section--routines",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Beauty Routines"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Heading Alignment",
      "options": [
        { "value": "center", "label": "Center" },
        { "value": "left", "label": "Left" }
      ],
      "default": "center"
    },
    {
      "type": "checkbox",
      "id": "alternate_layout",
      "label": "Alternate Layout (Image Left/Right)",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top Padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom Padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "Left Padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "Right Padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "routine",
      "name": "Routine",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Routine Title",
          "default": "Morning Skincare Routine"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>Start your day with this refreshing routine.</p>"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Routine Image"
        },
        {
          "type": "product_list",
          "id": "product_list",
          "label": "Related Products",
          "limit": 6
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "CTA Label",
          "default": "Shop Routine"
        },
        {
          "type": "url",
          "id": "cta_link",
          "label": "CTA Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Routines",
      "blocks": [
        {
          "type": "routine",
          "settings": {
            "title": "Evening Glow Routine",
            "description": "<p>Achieve radiant skin with these steps.</p>",
            "cta_label": "Get Started"
          }
        }
      ]
    }
  ]
}
{% endschema %}

{% comment %}
  CSS Additions for assets/base.css:
  - Ensure CSS variables are defined (e.g., --color-foreground for black, --color-background for white, --color-accent for gold, --shadow-hover for hover effects).
  - Add League Spartan font import if not already present: @import url('https://fonts.googleapis.com/css2?family=League+Spartan:wght@400;700&display=swap');
  - The stylesheet above includes basic rules; copy them to assets/base.css for global application.
  - For premium feel, add subtle animations and ensure responsive layout (stacked on mobile, two-column on desktop with alternating sides).
  Example additional rules:
  .routines__item {
    border: 1px solid var(--color-border);
  }
  .routines__title {
    color: var(--color-foreground);
  }
  .routines__description {
    color: var(--color-foreground);
    opacity: 0.8;
  }
{% endcomment %}