{% comment %}
  Modern Announcement Bar Section
  Compatible with: snippets/announcement-bar.liquid + announcement-bar.js + modular CSS
{% endcomment %}

{% if section.settings.enable_announcement %}
  {% render 'announcement-bar', section: section %}
{% endif %}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_announcement",
      "label": "Enable announcement bar",
      "default": true
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#e3f7c8"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#110933"
    },
    {
      "type": "checkbox",
      "id": "show_close_button",
      "label": "Show close button",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "text",
          "label": "Message text",
          "default": "Welcome to our store!"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar"
    }
  ]
}
{% endschema %}
