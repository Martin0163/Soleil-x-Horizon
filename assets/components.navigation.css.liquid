/* ============================================================================
   FILE: navigation.css
   Components: Navigation (Header, Mega Menu)
   ============================================================================ */

/* Mega Menu Layout */
.nav-dropdown--mega {
  min-width: 650px;
  padding: var(--space-lg);
}

.mega-menu-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: var(--space-xl);
}

.mega-menu-column {
  min-width: 0;
}

.mega-menu-title {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-bold);
  text-transform: uppercase;
  margin-bottom: var(--space-xs);
  color: var(--color-gray-800);
}

.mega-menu-list {
  list-style: none;
  margin: 0;
  padding: 0;
}

.mega-menu-list li + li {
  margin-top: var(--space-xs);
}

.mega-menu-list a {
  font-size: var(--font-size-sm);
  color: var(--color-gray-700);
  text-decoration: none;
  transition: color var(--duration-fast) var(--ease-out);
}

.mega-menu-list a:hover {
  color: var(--color-black);
}

/* Mega Menu Images */
.mega-menu-column--images img {
  width: 100%;
  border-radius: var(--radius-md);
  object-fit: cover;
  margin-bottom: var(--space-md);
  transition: transform var(--duration-fast) var(--ease-out);
}

.mega-menu-column--images img:hover {
  transform: scale(1.05);
}

/* Mega Menu Animation */
.nav-dropdown {
  opacity: 0;
  transform: translateY(-10px);
  pointer-events: none;
  transition: opacity 0.25s ease, transform 0.25s ease;
}

.nav-item:hover > .nav-dropdown {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

/* Mobile Menu */
.mobile-menu-wrapper {
  display: none;
}

@media (max-width: 1024px) {
  .mobile-menu-wrapper {
    display: block;
    width: 100%;
  }

  .mobile-menu-list {
    list-style: none;
    padding: 0;
    margin: 0;
    width: 100%;
  }

  .mobile-item {
    border-bottom: 1px solid var(--color-gray-200);
    padding: var(--space-md) 0;
  }

  .mobile-link {
    display: block;
    font-size: var(--font-size-lg);
    color: var(--color-black);
    text-decoration: none;
  }

  .mobile-item.has-submenu > .mobile-toggle {
    width: 100%;
    text-align: left;
    background: none;
    border: none;
    font-size: var(--font-size-lg);
    padding: 0;
    cursor: pointer;
  }

  .mobile-submenu {
    display: none;
    padding-left: var(--space-lg);
    margin-top: var(--space-sm);
  }

  .mobile-item.is-open > .mobile-submenu {
    display: block;
  }

  .mobile-subtitle {
    font-weight: bold;
    margin-top: var(--space-md);
    margin-bottom: var(--space-xs);
    text-transform: uppercase;
    font-size: var(--font-size-sm);
  }
}

/* Responsive Navigation */
@media (max-width: 1024px) {
  .nav-links {
    display: none;
  }
}

@media (min-width: 1025px) {
  .nav-links {
    display: flex;
  }

  .mobile-menu-wrapper {
    display: none !important;
  }

  .main-nav {
    position: static;
    height: auto;
    left: 0;
    transform: none;
  }
}

/* Wishlist Icon */
.header-wishlist {
  position: relative;
}

.wishlist-count {
  position: absolute;
  top: -4px;
  right: -4px;
  background: var(--color-error);
  color: var(--color-white);
  font-size: var(--font-size-xs);
  min-width: 18px;
  height: 18px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-full);
}

/* Cart Bubble */
.cart-bubble {
  --cart-padding: 0.2em;

  position: relative;
  width: 20px;
  aspect-ratio: 1;
  border-radius: 50%;
  border-width: 0;
  display: flex;
  line-height: normal;
  align-items: center;
  justify-content: center;
  color: var(--color-primary-button-text, var(--color-white));
  padding-inline: var(--cart-padding);
}

.cart-bubble__background {
  position: absolute;
  inset: 0;
  background-color: var(--color-primary-button-background, var(--color-primary-500));
  border-radius: var(--style-border-radius-lg, var(--radius-lg));
}

.cart-bubble__text {
  font-size: var(--font-size--3xs, 0.625rem);
  z-index: var(--layer-flat);
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Pills */
.pills__pill {
  --pills-pill-background-color: rgb(var(--color-foreground-rgb, 107 114 128) / var(--opacity-5-15));

  color: var(--color-text-primary);
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: var(--gap-sm);
  min-width: 48px;
  padding: 6px 12px;
  border-radius: var(--style-border-radius-pills, var(--radius-full));
  cursor: pointer;
  background-color: var(--pills-pill-background-color);
  transition: background-color var(--animation-speed) var(--animation-easing);
}

.pills__pill:hover {
  --pills-pill-background-color: rgb(var(--color-foreground-rgb, 107 114 128) / var(--opacity-10-25));
}

@media screen and (max-width: 749px) {
  .pills__pill {
    padding: var(--padding-xs) var(--padding-md);
  }
}

.pills__pill > .svg-wrapper {
  --close-icon-opacity: 0.4;
  --icon-stroke-width: 1px;

  color: var(--color-text-primary);
}

.pills__pill--swatch {
  @media screen and (max-width: 749px) {
    padding-inline-start: var(--padding-sm);
  }
}

.pills__pill--swatch .swatch {
  margin-right: -4px;
}

.pills__pill--desktop-small {
  @media screen and (min-width: 750px) {
    font-size: var(--font-size--xs, var(--font-size-xs));
  }
}

/* Bubble */
.bubble {
  display: inline-flex;
  height: calc(var(--variant-picker-swatch-height) / 1.5);
  font-size: var(--font-size--xs, var(--font-size-xs));
  border-radius: 20px;
  min-width: 20px;
  padding: 0 6px;
  background-color: rgb(var(--color-foreground-rgb, 107 114 128) / var(--opacity-10-25));
  color: var(--color-text-primary);
  align-items: center;
  justify-content: center;
}

.bubble svg {
  width: 12px;
  height: 12px;
}
