/* ============================================================================
   FILE: colors.css
   Design Tokens: Color System
   ============================================================================ */

:root {
  /* Base Horizon Colors */
  --color-bg-primary: #ffffff;
  --color-bg-secondary: #f7f7f7;
  --color-bg-tertiary: #efefef;

  --color-text-primary: #111111;
  --color-text-secondary: #555555;

  --color-border-light: #e5e5e5;
  --color-border-medium: #cccccc;
  --color-border-strong: #999999;

  /* Soleil Brand Colors */
  --color-brand-primary: #d4af37;
  --color-brand-secondary: #1a1a1a;
  --color-brand-accent: #f5e9c8;
  --color-brand-muted: #faf7f0;

  /* State Colors */
  --color-success: #2ecc71;
  --color-warning: #f1c40f;
  --color-error: #e74c3c;
  --color-info: #3498db;

  /* Dark Mode / High Contrast */
  --color-bg-primary-dark: #0f0f0f;
  --color-text-primary-dark: #f5f5f5;
  --color-brand-primary-dark: #caa32f;
}
