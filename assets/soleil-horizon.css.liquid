/* ============================================================================
   FILE: soleil-horizon.css
   Main CSS File for Soleil x Horizon Theme
   ============================================================================ */

/* Import Order:
   1. Tokens (Design System Variables)
   2. Base Styles (Reset, Typography, etc.)
   3. Layout (Grid, Sections, etc.)
   4. Components (Cards, Navigation, etc.)
   5. Utilities (Spacing, Text, etc.)
*/

/* ============================
   GLOBAL VARIABLES (TOKENS)
   ============================ */
:root {
  --header-height: 80px;
  --announcement-height: 36px;

  /* Puedes ajustar estos si quieres más separación */
  --header-bg: #ffffff;
  --announcement-bg: #e3f7c8;
}

/* 1. Tokens */
@import 'css-tokens.css';

/* 2. Base Styles */
@import 'css-base.css';

/* 3. Layout */
@import 'css-layout.css';

/* 4. Components */
@import 'css-components.css';

/* 5. Utilities */
@import 'css-utilities.css';

/* ============================
   ANNOUNCEMENT BAR
   ============================ */
.announcement-bar {
  height: var(--announcement-height);
  line-height: var(--announcement-height);
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--announcement-bg);
  position: relative;
  z-index: 60;
}

/* ============================
   HEADER
   ============================ */
.site-header {
  height: var(--header-height);
  background: var(--header-bg);
  position: sticky;
  top: var(--announcement-height);
  z-index: 50;
}
