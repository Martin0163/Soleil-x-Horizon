/* ============================================================================
   FILE: links-buttons.css
   Base Styles: Links and Buttons
   ============================================================================ */

/* Links */
a {
  --button-color: var(--color, var(--color-primary-500));

  color: var(--button-color);
  text-decoration: none;
  text-decoration-color: transparent;
  text-decoration-thickness: 0.075em;
  text-underline-offset: 0.125em;
  transition: color var(--transition-fast), text-decoration-color var(--animation-speed) var(--animation-easing);
}

a:hover {
  color: var(--color-primary-600);
}

a:focus {
  outline: 2px solid var(--color-primary-500);
  outline-offset: 2px;
}

:is(h1, h2, h3, h4, h5, h6, p) > a:hover {
  --button-color: var(--color, var(--color-primary-600));
}

p:not(.horizon-h1, .horizon-h2, .horizon-h3, .horizon-h4, .horizon-h5, .horizon-h6) a:where(:not(.button, .button-primary, .button-secondary, .btn, .btn-primary, .btn-secondary)),
.rte :is(p, ul, ol, table):not(.horizon-h1, .horizon-h2, .horizon-h3, .horizon-h4, .horizon-h5, .horizon-h6) a:where(:not(.button, .button-primary, .button-secondary, .btn, .btn-primary, .btn-secondary)) {
  text-decoration-color: currentcolor;
}

p:not(.horizon-h1, .horizon-h2, .horizon-h3, .horizon-h4, .horizon-h5, .horizon-h6) a:where(:not(.button, .button-primary, .button-secondary, .btn, .btn-primary, .btn-secondary)):hover,
.rte :is(p, ul, ol, table):not(.horizon-h1, .horizon-h2, .horizon-h3, .horizon-h4, .horizon-h5, .horizon-h6) a:where(:not(.button, .button-primary, .button-secondary, .btn, .btn-primary, .btn-secondary)):hover {
  text-decoration-color: transparent;
  color: var(--color-primary-600);
}

/* SoleilBeauty Button System */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-sm) var(--space-md);
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
  line-height: 1;
  border: 1px solid transparent;
  border-radius: var(--radius-md);
  cursor: pointer;
  transition: background-color var(--transition-fast),
              color var(--transition-fast),
              border-color var(--transition-fast);
  text-decoration: none;
  white-space: nowrap;
}

.btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.btn-primary {
  background-color: var(--color-primary-500);
  color: var(--color-white);
}

.btn-primary:hover:not(:disabled) {
  background-color: var(--color-primary-600);
}

.btn-secondary {
  background-color: transparent;
  color: var(--color-primary-500);
  border-color: var(--color-primary-500);
}

.btn-secondary:hover:not(:disabled) {
  background-color: var(--color-primary-500);
  color: var(--color-white);
}

/* Horizon Button System */
.button,
.button-secondary,
button.shopify-payment-button__button--unbranded {
  --text-align: center;

  display: grid;
  align-content: center;
  text-decoration: none;
  text-align: var(--text-align);
  color: var(--button-color);
  appearance: none;
  background-color: var(--button-background-color);
  border: none;
  font-family: var(--font-paragraph--family, var(--font-family-sans));
  font-style: var(--font-paragraph--style, normal);
  font-size: var(--font-paragraph--size, var(--font-size-base));
  line-height: var(--font-paragraph--line-height, var(--line-height-normal));
  margin-block: 0;
  transition: color var(--animation-speed) var(--animation-easing),
    box-shadow var(--animation-speed) var(--animation-easing),
    background-color var(--animation-speed) var(--animation-easing);
  cursor: pointer;
  width: fit-content;
  box-shadow: inset 0 0 0 var(--button-border-width) var(--button-border-color);
  padding-block: var(--button-padding-block);
  padding-inline: var(--button-padding-inline);
}

.button {
  font-family: var(--button-font-family-primary, var(--font-family-sans));
  text-transform: var(--button-text-case-primary, none);
  border-radius: var(--style-border-radius-buttons-primary, var(--radius-md));
}

.button:not(.button-secondary, .button-unstyled) {
  outline-color: var(--button-background-color);
}

.button-secondary {
  font-family: var(--button-font-family-secondary, var(--font-family-sans));
  text-transform: var(--button-text-case-secondary, none);
  border-radius: var(--style-border-radius-buttons-secondary, var(--radius-md));
}

button.shopify-payment-button__button--unbranded {
  font-family: var(--button-font-family-primary, var(--font-family-sans));
  text-transform: var(--button-text-case-primary, none);
}

.button[hidden] {
  display: none;
}

.button[aria-disabled='true'],
.button-secondary[aria-disabled='true'],
.button:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.button,
button.shopify-payment-button__button--unbranded {
  --button-color: var(--color-primary-button-text, var(--color-white));
  --button-background-color: var(--color-primary-button-background, var(--color-primary-500));
  --button-border-color: var(--color-primary-button-border, var(--color-primary-500));
  --button-border-width: var(--style-border-width-primary, 1px);
}

.button:hover,
button.shopify-payment-button__button--unbranded:hover:not([disabled]) {
  --button-color: var(--color-primary-button-hover-text, var(--color-white));
  --button-background-color: var(--color-primary-button-hover-background, var(--color-primary-600));
  --button-border-color: var(--color-primary-button-hover-border, var(--color-primary-600));
}

.button-secondary {
  --button-color: var(--color-secondary-button-text, var(--color-primary-500));
  --button-background-color: var(--color-secondary-button-background, transparent);
  --button-border-color: var(--color-secondary-button-border, var(--color-primary-500));
  --button-border-width: var(--style-border-width-secondary, 1px);
}

.button-secondary:hover {
  --button-color: var(--color-secondary-button-hover-text, var(--color-white));
  --button-background-color: var(--color-secondary-button-hover-background, var(--color-primary-500));
  --button-border-color: var(--color-secondary-button-hover-border, var(--color-primary-500));
}

button.shopify-payment-button__button--unbranded:hover:not([disabled]) {
  background-color: var(--button-background-color);
}

.button-unstyled {
  display: block;
  padding: 0;
  background-color: inherit;
  color: inherit;
  border: 0;
  border-radius: 0;
  overflow: hidden;
  box-shadow: none;
  font-family: var(--font-paragraph--family, var(--font-family-sans));
  font-style: var(--font-paragraph--style, normal);
  font-size: var(--font-paragraph--size, var(--font-size-base));
}

.button-unstyled:hover {
  background-color: inherit;
}

.button-unstyled--with-icon {
  color: var(--color-text-primary);
  display: flex;
  gap: var(--gap-2xs);
  align-items: center;
}

.button-unstyled--transparent {
  background-color: transparent;
  box-shadow: none;
}

/* Shopify Accelerated Checkout */
shopify-accelerated-checkout,
shopify-accelerated-checkout-cart {
  --shopify-accelerated-checkout-button-border-radius: var(--style-border-radius-buttons-primary, var(--radius-md));
  --shopify-accelerated-checkout-button-block-size: var(--height-buy-buttons);
}

.product-form-buttons:has(.add-to-cart-button.button-secondary)
  :is(shopify-accelerated-checkout, shopify-accelerated-checkout-cart) {
  --shopify-accelerated-checkout-button-border-radius: var(--style-border-radius-buttons-secondary, var(--radius-md));
  --shopify-accelerated-checkout-button-block-size: var(--height-buy-buttons);
}
