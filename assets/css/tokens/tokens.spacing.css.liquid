/* ============================================================================
   FILE: spacing.css
   Design Tokens: Spacing System
   ============================================================================ */

:root {
  /* Base Horizon Scale */
  --space-2xs: 0.25rem; /* 4px */
  --space-xs: 0.5rem;   /* 8px */
  --space-sm: 0.75rem;  /* 12px */
  --space-md: 1rem;     /* 16px */
  --space-lg: 1.5rem;   /* 24px */
  --space-xl: 2rem;     /* 32px */

  /* Soleil Extensions */
  --space-2xl: 3rem;    /* 48px */
  --space-3xl: 4rem;    /* 64px */
  --space-section: 6rem; /* 96px */
}
