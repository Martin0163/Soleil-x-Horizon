/* ============================================================================
   FILE: components.css
   Design Tokens: Component-Specific Tokens
   ============================================================================ */

:root {
  /* Announcement Bar */
  --announcement-bg: var(--color-brand-primary);
  --announcement-text: #ffffff;
  --announcement-speed: 20s;

  /* Mega Menu */
  --mega-menu-width: 100%;
  --mega-menu-padding: var(--space-lg);
  --mega-menu-column-gap: var(--space-xl);

  /* Buttons */
  --button-height: 48px;
  --button-padding: 0 24px;
  --button-radius: var(--radius-md);

  /* Cards */
  --card-padding: var(--space-md);
  --card-radius: var(--radius-md);
  --card-shadow: var(--shadow-sm);

  /* Slideshow */
  --slideshow-arrow-size: 40px;
  --slideshow-dot-size: 10px;

  /* Grid */
  --grid-item-radius: var(--radius-md);
  --grid-item-shadow: var(--shadow-sm);

  /* Forms */
  --input-height: 44px;
  --input-padding: 0 16px;
  --input-radius: var(--radius-sm);

  /* Header */
  --header-height: 72px;
  --header-padding: var(--space-md);

  /* Footer */
  --footer-padding: var(--space-xl);
  --footer-bg: var(--color-bg-secondary);
}
