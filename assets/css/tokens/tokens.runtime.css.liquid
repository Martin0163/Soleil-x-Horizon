/* ============================================================================
   FILE: runtime.css
   Design Tokens: Runtime Variables
   ============================================================================ */

:root {
  /* Header */
  --sticky-header-offset: 0px;

  /* Announcement Bar */
  --announcement-height: 0px;

  /* Fly-to-cart */
  --travel-x: 0px;
  --travel-y: 0px;
  --travel-scale: 0.25;
  --start-opacity: 1;

  /* Slideshow */
  --slideshow-gutter: 16px;
  --slideshow-height: auto;
  --slideshow-timeline: none;

  /* Grid */
  --product-grid-columns: 3;
  --product-grid-gap: 24px;
}
