/* ============================================================================
   FILE: announcement-bar.css
   Components: Announcement Bar
   ============================================================================ */

/* Base Announcement Bar */
.announcement-bar-section {
  --animation-speed: 30s;
  border-color: transparent !important;
  background-color: var(--announcement-bg-color, #e3f7c8);
}

.announcement-bar .localization-dropdown {
  background-color: var(--announcement-bg-color, #e3f7c8);
}

/* Announcement Bar Text */
.announcement-bar-section .announcement-bar .announcement-bar__message,
.announcement-bar-section .announcement-bar .announcement-bar__message *,
.announcement-bar-section .announcement-bar .announcement-bar__message ul li span,
.announcement-bar-section .announcement-bar .announcement_icon,
.announcement-bar-section .announcement-bar .announce_close,
.announcement-bar-section .country-select-box .detail-summary span,
.announcement-bar-section .country-select-box .detail-summary:after {
  color: var(--announcement-text-color, #110933);
}

/* Announcement Bar Button */
.announcement-bar-section .announcement-bar .announcement-bar__message .announce-btn {
  color: var(--announcement-button-text-color, #fcfcfc);
  background-color: var(--announcement-button-bg-color, #fcfcfc);
  border-color: var(--announcement-button-border-color, #ffffff);
}

/* Announcement Bar Marquee */
.announcement-bar__message-marquee {
  display: inline-block;
  animation: slideRight var(--animation-speed) linear infinite;
}

@keyframes slideRight {
  0% { transform: translateX(100%); }
  100% { transform: translateX(-100%); }
}

/* Announcement Bar Layout */
.announcement-bar-main-wrapper {
  display: flex;
  justify-content: center;
  align-items: center;
}

.announcement-bar-wrapper {
  overflow: hidden;
  white-space: nowrap;
}

.announcement-bar__message {
  display: inline-block;
  padding: 0 1rem;
}

/* Close Button */
.announce_close {
  position: absolute;
  top: 10px;
  right: 10px;
  background: none;
  border: none;
  font-size: 1.5rem;
  cursor: pointer;
  color: var(--announcement-text-color, #110933);
}

/* Responsive Adjustments */
@media (max-width: 749px) {
  .announcement-bar__message {
    font-size: 0.9rem;
  }
}
