/* ============================================================================
   FILE: product.css
   Components: Product-specific Components
   ============================================================================ */

/* Product Card */
.product-card {
  display: flex;
  flex-direction: column;
  height: 100%;
  position: relative;
  text-decoration: none;
  color: var(--color-text-primary);
}

.product-card__image-container {
  position: relative;
  overflow: hidden;
  border-radius: var(--radius-md);
  margin-bottom: var(--space-sm);
}

.product-card__image {
  width: 100%;
  height: auto;
  object-fit: cover;
  transition: transform var(--transition-normal);
}

.product-card:hover .product-card__image {
  transform: scale(1.05);
}

.product-card__info {
  display: flex;
  flex-direction: column;
  flex-grow: 1;
  padding: var(--space-sm) 0;
}

.product-card__title {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
  margin-bottom: var(--space-xs);
  color: var(--color-text-primary);
}

.product-card__price {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  margin-bottom: var(--space-xs);
}

.product-card__price--sale {
  color: var(--color-error);
}

.product-card__price--compare {
  text-decoration: line-through;
  color: var(--color-text-muted);
  margin-right: var(--space-xs);
}

.product-card__badge {
  position: absolute;
  top: var(--space-sm);
  left: var(--space-sm);
  background-color: var(--color-primary-500);
  color: var(--color-white);
  font-size: var(--font-size-xs);
  font-weight: var(--font-weight-medium);
  padding: var(--space-xs) var(--space-sm);
  border-radius: var(--radius-sm);
  z-index: 1;
}

.product-card__badge--sale {
  background-color: var(--color-error);
}

.product-card__badge--sold-out {
  background-color: var(--color-gray-600);
}

/* Product Grid */
.product-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: var(--space-md);
}

@media (max-width: 749px) {
  .product-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-sm);
  }
}

/* Product Variant Picker */
.variant-picker {
  margin-bottom: var(--space-md);
}

.variant-picker__label {
  display: block;
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  margin-bottom: var(--space-xs);
}

.variant-picker__options {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
}

.variant-picker__option {
  min-width: var(--variant-picker-swatch-width);
  height: var(--variant-picker-swatch-height);
  border: var(--variant-picker-border-width) solid rgba(0, 0, 0, var(--variant-picker-border-opacity));
  border-radius: var(--variant-picker-swatch-radius);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: border-color var(--transition-fast);
}

.variant-picker__option--selected {
  border-color: var(--color-primary-500);
  box-shadow: 0 0 0 1px var(--color-primary-500);
}

.variant-picker__option--color {
  position: relative;
  overflow: hidden;
}

.variant-picker__option--color::before {
  content: '';
  position: absolute;
  inset: 0;
  background-color: var(--color-value);
  border-radius: calc(var(--variant-picker-swatch-radius) - var(--variant-picker-border-width));
}

.variant-picker__option--text {
  padding: 0 var(--space-sm);
  font-size: var(--font-size-xs);
}

/* Product Inventory */
.product-inventory {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  margin-bottom: var(--space-md);
  font-size: var(--font-size-sm);
}

.product-inventory__icon {
  width: 16px;
  height: 16px;
}

.product-inventory--in-stock {
  color: var(--color-success);
}

.product-inventory--low-stock {
  color: var(--color-warning);
}

.product-inventory--out-of-stock {
  color: var(--color-error);
}

/* Product Form */
.product-form {
  margin-bottom: var(--space-xl);
}

.product-form__error {
  color: var(--color-error);
  font-size: var(--font-size-sm);
  margin-top: var(--space-xs);
}

.product-form__quantity {
  margin-bottom: var(--space-md);
}

.product-form__submit {
  width: 100%;
  margin-bottom: var(--space-md);
}

/* Quantity Selector */
.quantity-selector {
  display: flex;
  align-items: center;
  border: 1px solid var(--color-border-medium);
  border-radius: var(--radius-md);
  overflow: hidden;
  width: fit-content;
}

.quantity-selector__button {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: none;
  border: none;
  cursor: pointer;
  color: var(--color-text-primary);
}

.quantity-selector__button:hover {
  background-color: var(--color-gray-100);
}

.quantity-selector__button:disabled {
  color: var(--color-gray-400);
  cursor: not-allowed;
}

.quantity-selector__input {
  width: 40px;
  height: 36px;
  border: none;
  text-align: center;
  font-size: var(--font-size-sm);
  -moz-appearance: textfield;
}

.quantity-selector__input::-webkit-outer-spin-button,
.quantity-selector__input::-webkit-inner-spin-button {
  -webkit-appearance: none;
  margin: 0;
}

/* Product Price */
.product-price {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--space-xs);
  margin-bottom: var(--space-md);
}

.product-price__current {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-text-primary);
}

.product-price__compare {
  font-size: var(--font-size-base);
  color: var(--color-text-muted);
  text-decoration: line-through;
}

.product-price__sale {
  font-size: var(--font-size-base);
  color: var(--color-error);
  font-weight: var(--font-weight-medium);
}

/* Product Custom Property */
.product-custom-property {
  margin-bottom: var(--space-md);
}

.product-custom-property__label {
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  margin-bottom: var(--space-xs);
}

.product-custom-property__value {
  font-size: var(--font-size-base);
}

/* Product SKU */
.product-sku {
  font-size: var(--font-size-xs);
  color: var(--color-text-muted);
  margin-bottom: var(--space-md);
}

/* Product Hotspot */
.product-hotspot {
  position: absolute;
  transform: translate(-50%, -50%);
  z-index: var(--layer-raised);
}

.product-hotspot__button {
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background-color: var(--color-white);
  border: 1px solid var(--color-border-medium);
  box-shadow: var(--shadow-md);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: transform var(--transition-fast);
}

.product-hotspot__button:hover {
  transform: scale(1.1);
}

.product-hotspot__content {
  position: absolute;
  bottom: calc(100% + 10px);
  left: 50%;
  transform: translateX(-50%);
  background-color: var(--color-white);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-lg);
  padding: var(--space-md);
  width: 200px;
  display: none;
}

.product-hotspot__content::after {
  content: '';
  position: absolute;
  top: 100%;
  left: 50%;
  transform: translateX(-50%);
  border-width: 8px;
  border-style: solid;
  border-color: var(--color-white) transparent transparent transparent;
}

.product-hotspot:hover .product-hotspot__content {
  display: block;
}
