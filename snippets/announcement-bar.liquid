{%- if section.settings.enable_announcement and section.blocks.size > 0 -%}
  <announcement-bar
  class="announcement-bar announcement-bar--{{ section.settings.animation_style }}"
  data-storage-key="announcement_closed_v1"
  data-animation="{{ section.settings.animation_style }}"
  style="
    --announcement-bg: {{ section.settings.background_color }};
    --announcement-text: {{ section.settings.text_color }};
    --announcement-speed: {{ section.settings.animation_speed }}s;
  "
>

    <div class="announcement-bar__inner">

      <div class="announcement-bar__messages" data-announcement-messages>
        <div class="announcement-bar__track">
          {% for block in section.blocks %}
            <div class="announcement-bar__message"> {{ block.settings.text }}</div>
              {% endfor %}
            </div>

    </div>
  </announcement-bar>
{%- endif -%}




