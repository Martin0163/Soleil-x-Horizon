{% comment %}
/* Start Soleil Color Bridge Snippet */
  Purpose: Maps Soleil Beauty design system CSS variables to Horizon's native
           color scheme system. Bridges the gap between:
           - Soleil vars: --color-yellow, --color-black, --color-white, etc.
           - Horizon vars: --color-foreground, --color-background, --color-primary, etc.
  
  Also applies:
  - Soleil yellow gradient to Horizon's header
  - Google Fonts (Inter + Playfair Display) via preconnect
  - Global typography overrides using Soleil font stack
  - Scroll-hide header behavior matching Soleil Beauty shop
  
  Usage: Rendered inside <head> via snippets/soleil-stylesheets.liquid
  Load order: After theme-styles-variables + color-schemes, before content_for_header
/* End Soleil Color Bridge Snippet */
/* You can paste future updates here without breaking anything */
{% endcomment %}

{% comment %} /* Start: Google Fonts — Inter + Playfair Display */ {% endcomment %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link
  href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&display=swap"
  rel="stylesheet"
>
{% comment %} /* End: Google Fonts */ {% endcomment %}

{% comment %} /* Start: Soleil → Horizon CSS Variable Bridge */ {% endcomment %}
<style>
  /* ============================================================
     Start Soleil Color Bridge — CSS Variable Mapping
     Maps Soleil Beauty design tokens to Horizon color scheme vars
     ============================================================ */

  :root {
    /* ── Soleil Brand Colors ── */
    --color-black:        #000000;
    --color-white:        #FFFFFF;
    --color-yellow:       #FFD700;
    --color-yellow-dark:  #E6A500;
    --color-yellow-light: #FFF3B0;

    /* ── Soleil Neutrals ── */
    --color-gray-50:  #FAF9F7;
    --color-gray-100: #F5F5F0;
    --color-gray-200: #E5E7EB;
    --color-gray-300: #D6D3D1;
    --color-gray-400: #9CA3AF;
    --color-gray-500: #8D8D8D;
    --color-gray-600: #4B5563;
    --color-gray-700: #4A4A4A;
    --color-gray-800: #1F2937;
    --color-gray-900: #111827;

    /* ── Soleil Semantic Colors ── */
    --color-success: #4CAF50;
    --color-error:   #E63946;
    --color-warning: #E6B800;
    --color-info:    #6A5ACD;

    /* ── Soleil Beauty Accents ── */
    --color-blush: #F4C2C2;
    --color-nude:  #D8BFAA;
    --color-plum:  #6D3B47;
    --color-cream: #FFF8E7;

    /* ── Soleil Gradients ── */
    --gradient-yellow:  linear-gradient(135deg, var(--color-yellow) 0%, var(--color-yellow-dark) 100%);
    --gradient-header:  linear-gradient(90deg, #f7ca00 0%, #ffd700 100%);
    --gradient-dark:    linear-gradient(135deg, var(--color-gray-900) 0%, var(--color-black) 100%);
    --gradient-light:   linear-gradient(135deg, var(--color-white) 0%, var(--color-gray-50) 100%);

    /* ── Soleil Shadows ── */
    --shadow-xs:     0 1px 2px 0 rgba(0,0,0,0.05);
    --shadow-sm:     0 1px 3px 0 rgba(0,0,0,0.1), 0 1px 2px 0 rgba(0,0,0,0.06);
    --shadow-md:     0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -1px rgba(0,0,0,0.06);
    --shadow-lg:     0 10px 15px -3px rgba(0,0,0,0.1), 0 4px 6px -2px rgba(0,0,0,0.05);
    --shadow-xl:     0 20px 25px -5px rgba(0,0,0,0.1), 0 10px 10px -5px rgba(0,0,0,0.04);
    --shadow-2xl:    0 25px 50px -12px rgba(0,0,0,0.25);
    --shadow-yellow: 0 10px 30px -5px rgba(255,215,0,0.3);

    /* ── Soleil Spacing ── */
    --space-xs:  0.25rem;
    --space-sm:  0.5rem;
    --space-md:  1rem;
    --space-lg:  1.5rem;
    --space-xl:  2rem;
    --space-2xl: 3rem;
    --space-3xl: 4rem;
    --space-4xl: 6rem;
    --space-5xl: 8rem;

    /* ── Soleil Typography Scale ── */
    --font-size-xs:   0.75rem;
    --font-size-sm:   0.875rem;
    --font-size-base: 1rem;
    --font-size-lg:   1.125rem;
    --font-size-xl:   1.25rem;
    --font-size-2xl:  1.5rem;
    --font-size-3xl:  1.875rem;
    --font-size-4xl:  2.25rem;
    --font-size-5xl:  3rem;
    --font-size-6xl:  3.75rem;

    /* ── Soleil Font Weights ── */
    --font-weight-light:    300;
    --font-weight-normal:   400;
    --font-weight-medium:   500;
    --font-weight-semibold: 600;
    --font-weight-bold:     700;

    /* ── Soleil Line Heights ── */
    --line-height-tight:   1.25;
    --line-height-normal:  1.5;
    --line-height-relaxed: 1.75;

    /* ── Soleil Border Radius ── */
    --radius-sm:   0.25rem;
    --radius-md:   0.375rem;
    --radius-lg:   0.5rem;
    --radius-xl:   0.75rem;
    --radius-2xl:  1rem;
    --radius-full: 9999px;

    /* ── Soleil Transitions ── */
    --duration-fast:   150ms;
    --duration-base:   300ms;
    --duration-slow:   500ms;
    --ease-in:         cubic-bezier(0.4, 0, 1, 1);
    --ease-out:        cubic-bezier(0, 0, 0.2, 1);
    --ease-in-out:     cubic-bezier(0.4, 0, 0.2, 1);
    --ease-bounce:     cubic-bezier(0.68, -0.55, 0.265, 1.55);

    /* ── Soleil Z-Index Scale ── */
    --z-dropdown:       1000;
    --z-sticky:         1020;
    --z-fixed:          1030;
    --z-modal-backdrop: 1040;
    --z-modal:          1050;
    --z-popover:        1060;
    --z-tooltip:        1070;

    /* ── Soleil Fonts ── */
    --font-body:    'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    --font-heading: 'Playfair Display', Georgia, 'Times New Roman', serif;
  }

  /* ============================================================
     Start Soleil → Horizon Color Scheme Bridge
     Overrides Horizon's color scheme CSS vars with Soleil values
     Applied to scheme-1 (primary scheme) by default
     ============================================================ */

  /* Bridge: Horizon scheme vars → Soleil brand colors */
  .color-scheme-1,
  .color-scheme-2,
  [class*="color-scheme"] {
    /* These are additive — Horizon's own vars still work */
    --soleil-accent:       var(--color-yellow);
    --soleil-accent-dark:  var(--color-yellow-dark);
    --soleil-accent-light: var(--color-yellow-light);
  }

  /* ── Global Typography Override ── */
  body {
    font-family: var(--font-body);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  h1, h2, h3, h4, h5, h6,
  .h1, .h2, .h3, .h4, .h5, .h6 {
    font-family: var(--font-heading);
  }

  /* ── Selection Color ── */
  ::selection {
    background-color: var(--color-yellow);
    color: var(--color-black);
  }

  ::-moz-selection {
    background-color: var(--color-yellow);
    color: var(--color-black);
  }

  /* ── Focus Visible ── */
  *:focus-visible {
    outline: 2px solid var(--color-yellow);
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }

  /* End Soleil → Horizon Color Scheme Bridge */

  /* ============================================================
     Start Soleil Header Yellow Gradient Override
     Applies Soleil Beauty's signature yellow gradient to
     Horizon's native header component
     ============================================================ */

  /* Target Horizon's header-component custom element */
  header-component,
  .header-section header-component,
  .shopify-section-group-header-group header-component {
    background: var(--gradient-header) !important;
    color: var(--color-black) !important;
  }

  /* Header inner wrapper */
  header-component .header__inner,
  header-component .header-wrapper,
  header-component > div {
    background: transparent;
  }

  /* Header links — black on yellow */
  header-component a,
  header-component button,
  header-component .header__menu-item,
  header-component nav a {
    color: var(--color-black) !important;
  }

  header-component a:hover,
  header-component button:hover,
  header-component .header__menu-item:hover {
    color: var(--color-yellow-dark) !important;
    opacity: 1 !important;
  }

  /* Header icons — black */
  header-component svg,
  header-component .icon {
    color: var(--color-black) !important;
    stroke: var(--color-black) !important;
    fill: none;
  }

  /* Scrolled state — slightly darker gradient */
  header-component.is-scrolled,
  header-component[data-scrolled] {
    background: linear-gradient(90deg, #e6b800 0%, #ffca00 100%) !important;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15) !important;
  }

  /* Logo on yellow header */
  header-component .header__logo,
  header-component .site-logo {
    filter: none;
  }

  /* Cart bubble on yellow header */
  header-component cart-bubble,
  header-component .cart-count-bubble {
    background: var(--color-black) !important;
    color: var(--color-white) !important;
  }

  /* End Soleil Header Yellow Gradient Override */

  /* ============================================================
     Start Soleil Button Global Overrides
     Applies Soleil button styles to Horizon's native buttons
     ============================================================ */

  /* Primary button — yellow gradient */
  .button,
  .btn,
  button[type="submit"].button,
  a.button {
    font-family: var(--font-body);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.02em;
    transition: transform var(--duration-base) var(--ease-out),
                box-shadow var(--duration-base) var(--ease-out),
                background-color var(--duration-base) var(--ease-out);
  }

  .button:hover,
  .btn:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  /* End Soleil Button Global Overrides */

  /* ============================================================
     Start Soleil Announcement Bar Styling
     Applies Soleil's black announcement bar style to
     Horizon's native announcement bar section
     ============================================================ */

  .announcement-bar-section,
  .shopify-section-group-header-group .announcement-bar-section {
    background: var(--color-black) !important;
    color: var(--color-white) !important;
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }

  .announcement-bar-section a {
    color: var(--color-yellow) !important;
  }

  .announcement-bar-section a:hover {
    color: var(--color-yellow-light) !important;
  }

  /* End Soleil Announcement Bar Styling */

  /* ============================================================
     Start Soleil Visual Separation
     Clear separation between announcement bar, header, content
     ============================================================ */

  /* Announcement bar → Header separation */
  .shopify-section-group-header-group > .shopify-section:first-child {
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }

  /* Header → Content separation */
  #header-group {
    box-shadow: 0 2px 12px rgba(0,0,0,0.08);
  }

  /* Main content top spacing when header is sticky */
  .content-for-layout {
    padding-top: 0;
  }

  /* End Soleil Visual Separation */

  /* ============================================================
     Start Soleil Scroll-Hide Header Behavior
     Matches Soleil Beauty shop's header scroll behavior:
     - Adds shadow on scroll
     - Hides on scroll down, shows on scroll up
     ============================================================ */

  header-component {
    transition: transform var(--duration-base) var(--ease-out),
                box-shadow var(--duration-base) var(--ease-out),
                background var(--duration-base) var(--ease-out) !important;
    will-change: transform;
  }

  header-component.header--hidden {
    transform: translateY(-100%);
  }

  /* End Soleil Scroll-Hide Header Behavior */

</style>
{% comment %} /* End: Soleil → Horizon CSS Variable Bridge */ {% endcomment %}

{% comment %} /* Start: Scroll-Hide Header JS */ {% endcomment %}
<script>
  /* Start Soleil Header Scroll Behavior */
  (function initSoleilHeaderScroll() {
    'use strict';

    document.addEventListener('DOMContentLoaded', function () {
      var header = document.querySelector('header-component');
      if (!header) return;

      var lastScrollY   = 0;
      var scrollThresh  = 80;
      var hideThresh    = 200;
      var ticking       = false;

      function onScroll() {
        if (!ticking) {
          requestAnimationFrame(function () {
            var scrollY = window.scrollY || window.pageYOffset;

            /* Add scrolled class for shadow */
            if (scrollY > 50) {
              header.setAttribute('data-scrolled', '');
              header.classList.add('is-scrolled');
            } else {
              header.removeAttribute('data-scrolled');
              header.classList.remove('is-scrolled');
            }

            /* Hide on scroll down, show on scroll up */
            if (scrollY > hideThresh) {
              if (scrollY > lastScrollY) {
                header.classList.add('header--hidden');
              } else {
                header.classList.remove('header--hidden');
              }
            } else {
              header.classList.remove('header--hidden');
            }

            lastScrollY = Math.max(0, scrollY);
            ticking = false;
          });
          ticking = true;
        }
      }

      window.addEventListener('scroll', onScroll, { passive: true });
    });
  })();
  /* End Soleil Header Scroll Behavior */
</script>
{% comment %} /* End: Scroll-Hide Header JS */ {% endcomment %}
